# 管理员设置密码
# 用于访问高级设置
ADMIN_SETTING_PASSWORD=

# 阿里云通义千问API密钥
# 获取地址: https://dashscope.console.aliyun.com/
# 支持qwen系列模型，包括qwen-turbo、qwen-plus、qwen-max等
ALIBABA_API_KEY=

# API请求基础URL（可选）
# 用于自定义API代理或私有部署的服务地址
# 默认: https://dashscope.aliyuncs.com/compatible-mode/v1
# 代理示例: http://your-api-proxy.com
# 私有部署示例: http://your-private-server.com/v1
# 注意: 确保与自定义模型的API接口一致
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认AI模型（可选）
# 指定系统启动时的默认模型
# 推荐模型: qwen-turbo-latest, qwen-plus-latest, qwen-max-latest
# 留空则使用系统内置默认模型
DEFAULT_MODEL=qwen-turbo-latest

# 默认AI服务提供商（可选）
# 指定系统启动时的默认服务商
# 可用值: Alibaba, Azure, Google, Anthropic, Baidu, ByteDance, Tencent, Moonshot, Iflytek, DeepSeek, XAI, ChatGLM, SiliconFlow
# 注意: 确保对应的API密钥已正确配置
DEFAULT_PROVIDER=Alibaba

# 字节跳动豆包 API 密钥
# 获取地址: https://console.volcengine.com/ark
BYTEDANCE_API_KEY=

# DeepSeek API 密钥
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 数据库配置
# 推荐使用MySQL数据库
# 数据库连接字符串
# 示例: mysql+pymysql://username:password@host:port/database
DATABASE_URL=mysql+pymysql://username:password@host:port/database

# MCP（Model Context Protocol）功能开关
# true: 启用MCP工具生态，支持丰富的第三方工具集成
# false: 禁用MCP功能，仅使用内置工具
# 推荐保持启用以获得最佳体验
ENABLE_MCP=true

# 前端客户端 API 配置（浏览器端可访问）
# 必须以 NEXT_PUBLIC_ 开头才能在客户端使用
# 默认: http://localhost:5000
# 生产环境示例: https://www.ifish.me
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# 前端日志输出控制（浏览器端可访问）
# 控制是否在浏览器控制台输出日志信息
# true: 启用日志输出（推荐用于开发和调试）
# false: 禁用日志输出（推荐用于生产环境以提高安全性）
# 默认: 如果未设置，则根据 NEXT_PUBLIC_API_BASE_URL 自动判断
#       包含 localhost 或 127.0.0.1 时启用日志，其他情况禁用日志
NEXT_PUBLIC_ENABLE_LOGGING=true

# 对比模式最少选择平台数（可选）
# 设置对比模式下最少需要选择的平台数量
# 默认值: 2
COMPARE_MIN_MODELS=2

# 对比模式最多选择平台数（可选）
# 设置对比模式下最多允许选择的平台数量
# 默认值: 4
COMPARE_MAX_MODELS=4

# 对比模式各平台默认模型配置（可选）
# 设置对比模式中各AI平台的默认模型
# 留空则使用系统内置默认模型
COMPARE_DEFAULT_DEEPSEEK_MODEL=deepseek-chat
COMPARE_DEFAULT_BYTEDANCE_MODEL=doubao-seed-2-0-lite-260215
COMPARE_DEFAULT_ALIBABA_MODEL=qwen-turbo
COMPARE_DEFAULT_BAIDU_MODEL=ernie-4.0-8k
COMPARE_DEFAULT_TENCENT_MODEL=hunyuan-lite
COMPARE_DEFAULT_MOONSHOT_MODEL=moonshot-v1-8k
COMPARE_DEFAULT_CHATGLM_MODEL=glm-4-flash
